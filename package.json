{
    "name": "mca-json",
    "version": "1.2.1",
    "description": "Convert Minecraft MCA (Anvil files) and NBT into JSON and back, or modify directly in memory. Works on region files and player data.",
    "keywords": [
        "minecraft",
        "mca",
        "nbt",
        "snbt",
        "json",
        "anvil",
        "region",
        "dat"
    ],
    "bin": {
        "mca-chunks": "dist/bin/mca-chunks.js",
        "mca-json": "dist/bin/mca-json.js"
    },
    "scripts": {
        "build": "rm -rf dist && npm run build-index && tsc",
        "build-index": "cd src; for F in $(grep '^export' -r . -l --include \\*.ts --exclude index.ts); do echo \"export * from '${F%.ts}.js';\"; done | LC_ALL=C sort > index.ts",
        "reinstall": "rm -rf node_modules package-lock.json && npm install"
    },
    "type": "module",
    "main": "dist/index.js",
    "dependencies": {
        "debug": "^4.4.3",
        "get-stdin": "^10.0.0",
        "neodoc": "^2.0.2",
        "pako": "^2.1.0"
    },
    "devDependencies": {
        "@types/debug": "^4.1.12",
        "@types/node": "^25.3.3",
        "@types/pako": "^2.0.4",
        "typescript": "^5.9.3"
    },
    "author": "Tyler Akins <fidian@rumkin.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/fidian/mca-json.git"
    },
    "bugs": {
        "url": "https://github.com/fidian/mca-json/issues"
    },
    "homepage": "https://github.com/fidian/mca-json#readme"
}
